# Genius Sports API key (required)
GENIUS_API_KEY=

# Slack bot token (optional for local, required in CI)
SLACK_BOT_TOKEN=

# Google Drive folder ID for uploading the Excel output
GDRIVE_FOLDER_ID=

# Path to Google Service Account JSON (for local development only; CI uses GDRIVE_SA_JSON secret)
# GDRIVE_SA_JSON_PATH=service_account.json
